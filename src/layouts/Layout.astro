---
import '@/styles/global.css';
import SiteHeader from '@/components/SiteHeader.astro';
import { PageCat } from '@/components/PageCat';
import { formatPageTitle, getTitleBootPayload, fontStylesheetUrl } from '@/i18n/index';
import { withBase } from '@/lib/base-url';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  pageKey?: 'quotes' | 'authors' | 'settings' | 'focus';
  hideCat?: boolean;
}

const { pageKey = 'quotes', title, hideCat = false } = Astro.props;
const resolvedTitle = title ?? formatPageTitle(pageKey, 'zh-Hant');
const titleBoot = getTitleBootPayload();
const defaultFontUrl = fontStylesheetUrl('zh-Hant');
const fontUrls = {
  'zh-Hant': fontStylesheetUrl('zh-Hant'),
  en: fontStylesheetUrl('en'),
  ja: fontStylesheetUrl('ja'),
};
---

<!doctype html>
<html lang="zh-Hant" data-theme="light" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={titleBoot['zh-Hant'].description} />
    <meta name="theme-color" content="#8b6914" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="manifest" href={withBase('manifest.webmanifest')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link id="wq-fonts" rel="stylesheet" href={defaultFontUrl} />
    <title>{resolvedTitle}</title>
    <ClientRouter />
    <script is:inline define:vars={{ titleBoot, pageKey, fontUrls }}>
      (function () {
        const storedTheme = localStorage.getItem('wq-theme');
        document.documentElement.dataset.theme = storedTheme === 'dark' ? 'dark' : 'light';

        const storedLocale = localStorage.getItem('wq-locale');
        const locale = storedLocale === 'en' || storedLocale === 'ja' ? storedLocale : 'zh-Hant';
        document.documentElement.lang = locale;

        const fontLink = document.getElementById('wq-fonts');
        if (fontLink && fontUrls[locale]) fontLink.href = fontUrls[locale];

        const m = titleBoot[locale];
        if (m?.page?.[pageKey]) {
          document.title = m.app + ' — ' + m.page[pageKey];
        }
        if (m?.description) {
          const meta = document.querySelector('meta[name="description"]');
          if (meta) meta.setAttribute('content', m.description);
        }

        window.addEventListener('wq-locale-change', (event) => {
          const loc = event.detail?.locale;
          if (!loc || !fontUrls[loc]) return;
          const link = document.getElementById('wq-fonts');
          if (link) link.href = fontUrls[loc];
        });
      })();
    </script>
    <script is:inline define:vars={{ swUrl: withBase('sw.js'), swScope: withBase() }}>
      if ('serviceWorker' in navigator) {
        const isLocal =
          location.hostname === 'localhost' || location.hostname === '127.0.0.1';
        if (isLocal) {
          // SW cache-first breaks ClientRouter during local dev; clear any stale registration.
          navigator.serviceWorker.getRegistrations().then((regs) => {
            for (const reg of regs) reg.unregister();
          });
        } else {
          window.addEventListener('load', () => {
            navigator.serviceWorker.register(swUrl, { scope: swScope }).catch(() => {});
          });
        }
      }
    </script>
  </head>
  <body>
    {!hideCat && <PageCat client:idle transition:persist="page-cat" />}
    <div class="app">
      <SiteHeader activePage={pageKey} />
      <div transition:animate="fade">
        <slot />
      </div>
    </div>
  </body>
</html>